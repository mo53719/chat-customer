# ============ LLM 推理配置 ============
# 支持任意 OpenAI 兼容协议的模型服务（GLM / Qwen / DeepSeek / Moonshot / 豆包 / OpenAI 等）
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=glm-4-plus
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=60

# ============ Embedding 向量化配置 ============
# 后端类型：local（fastembed + Qdrant ONNX） | openai（OpenAI 兼容协议）
EMBEDDING_BACKEND=local
# 本地模型路径（相对项目根），含完整 HF 缓存结构
EMBEDDING_LOCAL_PATH=models/qdrant-bge-small-zh-v1.5
# fastembed 识别的模型名（HF 仓库名）
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
EMBEDDING_LOCAL_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32
EMBEDDING_NORMALIZE=true
# 以下仅在 EMBEDDING_BACKEND=openai 时生效
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_MODEL=text-embedding-v3
# 维度必须与本地模型一致（Qdrant/bge-small-zh-v1.5 = 512）
EMBEDDING_DIM=512

# ============ Rerank 配置 ============
RERANK_ENABLED=true
RERANK_MODEL=BAAI/bge-reranker-base
RERANK_TOP_N=20
RERANK_FINAL_K=5

# HuggingFace 国内镜像，让 fastembed 能下载 reranker 模型
HF_ENDPOINT=https://hf-mirror.com
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# ============ Qdrant 向量库（云端） ============
# 填入你的 Qdrant Cloud 集群地址，例如 https://xxxxxx.aws.qdrant.io:6333
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=chat_customer_kb
# 商品知识库集合（售前 Agent 检索用）
QDRANT_PRODUCT_COLLECTION=product_kb
QDRANT_LONG_TERM_COLLECTION=user_long_term_memory

# ============ SQLite 数据库 ============
SQLITE_PATH=data/chat_customer.db
SQLITE_WAL=true

# ============ 安全鉴权 ============
JWT_SECRET=change_me_to_a_random_long_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
API_KEY_HEADER=X-API-Key
RATE_LIMIT_PER_MINUTE=60

# ============ 熔断 / 限流 / 超时 ============
MAX_TOOL_ROUNDS=6
TASK_TIMEOUT_SEC=60
CIRCUIT_FAIL_THRESHOLD=5
CIRCUIT_RECOVER_SEC=30
LLM_RETRY_MAX=3
LLM_RETRY_BACKOFF=1.5

# ============ 上下文记忆 ============
CONTEXT_MAX_TOKENS=4000
SHORT_TERM_WINDOW=20

# ============ 兜底话术 ============
FALLBACK_TEXT=抱歉，我暂时无法处理您的请求，已为您转接人工客服。

# ============ 服务端口 ============
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============ 日志 ============
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_ROTATION=10 MB
LOG_RETENTION=30 days